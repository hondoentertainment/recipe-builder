      "title": "Orange Oatmeal Cookies",
      "description": "Vintage cookbook cookie recipe with oats, nuts, and candied orange peel.",
      "servings": "About 4 dozen",
      "prep_time": "20 minutes",
      "cook_time": "10\u201312 minutes",
      "ingredients": [
        "2 cups sifted enriched flour",
        "1 teaspoon baking soda",
        "1 teaspoon salt",
        "1 cup shortening",
        "1 cup sugar",
        "1/2 cup brown sugar, firmly packed",
        "2 eggs",
